# Micro Cockpit — environment template.
# Copy to `.env` and replace every value before exposing the stack: `cp .env.example .env`
# These are deliberate placeholders, NOT usable production secrets.
# Compose fails fast if any required variable is unset (the `${VAR:?...}` form).

# --- superuser + migrator (full DB control; keep secret) ---
POSTGRES_PASSWORD=change-me-postgres-superuser
MIGRATOR_DB_PASSWORD=change-me-migrator

# --- per-service DB roles (each role can DML only its own schema) ---
IDENTITY_DB_PASSWORD=change-me-identity
JOURNAL_DB_PASSWORD=change-me-journal
PERFORMANCE_DB_PASSWORD=change-me-performance
DISCIPLINE_DB_PASSWORD=change-me-discipline
REMINDER_DB_PASSWORD=change-me-reminder
STOCK_RESEARCH_DB_PASSWORD=change-me-stock-research
MARKET_DATA_DB_PASSWORD=change-me-market-data
PRICE_ALERT_DB_PASSWORD=change-me-price-alert
ROTATION_DB_PASSWORD=change-me-rotation
PARTNER_DB_PASSWORD=change-me-partner
CONTENT_DB_PASSWORD=change-me-content
OPERATIONS_DB_PASSWORD=change-me-operations

# --- application secrets ---
# Public browser signup is disabled by default. For local development only, set:
# ALLOW_PUBLIC_REGISTRATION=true
ALLOW_PUBLIC_REGISTRATION=false
# Registration gate when public registration is disabled (curl / bootstrap; never put this in the browser).
LOCAL_REGISTRATION_KEY=change-me-registration-key
# Shared key for internal service-to-service calls (outbox events, worker runs, market ingestion).
INTERNAL_SERVICE_KEY=change-me-internal-service-key

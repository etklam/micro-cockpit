  "components": {
    "schemas": {
      "CalculateResponse": {
        "required": [
          "universeId",
          "snapshotDate",
          "status",
          "formulaVersion"
        ],
        "type": "object",
        "properties": {
          "universeId": {
            "type": "string",
            "format": "uuid"
          },
          "snapshotDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string"
          },
          "formulaVersion": {
            "type": "string"
          }
        }
      },
      "CollectionResponseOfUniverseResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UniverseResponse"
            }
          }
        }
      },
      "EtfSnapshotResponse": {
        "required": [
          "symbol",
          "label",
          "sector",
          "close",
          "return2w",
          "return1m",
          "return3m",
          "rank2w",
          "rankGroup",
          "percentile2w",
          "aboveMa20",
          "aboveMa50",
          "aboveMa200",
          "status"
        ],
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "sector": {
            "type": [
              "null",
              "string"
            ]
          },
          "close": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "return2w": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "return1m": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "return3m": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "rank2w": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "rankGroup": {
            "type": "string"
          },
          "percentile2w": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "aboveMa20": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "aboveMa50": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "aboveMa200": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "status": {
            "type": "string"
          }
        }
      },
      "MonitorMarketState": {
        "required": [
          "state",
          "breadthPercent",
          "benchmarkAboveMa200",
          "status"
        ],
        "type": "object",
        "properties": {
          "state": {
            "type": [
              "null",
              "string"
            ]
          },
          "breadthPercent": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "benchmarkAboveMa200": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "status": {
            "type": "string"
          }
        }
      },
      "MonitorResponse": {
        "required": [
          "universe",
          "snapshotDate",
          "formulaVersion",
          "status",
          "marketState",
          "sectorBreadth",
          "etfs"
        ],
        "type": "object",
        "properties": {
          "universe": {
            "$ref": "#/components/schemas/MonitorUniverse"
          },
          "snapshotDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "formulaVersion": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "marketState": {
            "$ref": "#/components/schemas/MonitorMarketState"
          },
          "sectorBreadth": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SectorBreadthResponse"
            }
          },
          "etfs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EtfSnapshotResponse"
            }
          }
        }
      },
      "MonitorUniverse": {
        "required": [
          "id",
          "code",
          "name",
          "rankScope"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "rankScope": {
            "type": "string"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },

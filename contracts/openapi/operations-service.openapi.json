          "serviceName",
          "status"
        ],
        "type": "object",
        "properties": {
          "serviceName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "JobAcceptedResponse": {
        "required": [
          "id",

      },
      "AuditWrite": {
        "required": [
          "action",
          "resourceType",
          "resourceId",
          "details"
        ],
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "resourceId": {
            "type": [
              "null",
              "string"
            ]
          },
          "details": {
            "$ref": "#/components/schemas/JsonElement"
          }
        }
      },
      "CollectionResponseOfAuditResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuditResponse"
            }
          }
        }
      },
      "CollectionResponseOfJobResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobResponse"
            }
          }
        }
      },
      "HealthWrite": {

        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "actorUserId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "action": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "resourceId": {
            "type": [
              "null",
              "string"
            ]
          },
          "details": {
            "$ref": "#/components/schemas/JsonElement"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          }

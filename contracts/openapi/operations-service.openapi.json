            "type": "string"
          }
        }
      },
      "JobResponse": {
        "required": [
          "id",
          "jobType",
          "status",
          "requestedBy",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "jobType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "requestedBy": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "JobWrite": {
        "required": [
          "jobType",

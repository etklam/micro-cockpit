          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DiaryWrite": {
        "required": [
          "localDate",
          "title",
          "content"
        ],
        "type": "object",
        "properties": {
          "localDate": {
            "type": "string",
            "format": "date"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "QuickNote": {
        "required": [
          "localDate",
          "content",
          "targetDiaryId"
        ],
        "type": "object",
        "properties": {
          "localDate": {
            "type": "string",
            "format": "date"
          },
          "content": {
            "type": "string"
          },
          "targetDiaryId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "QuickNoteResponse": {
        "required": [
          "diaryId",
          "appended"
        ],
        "type": "object",
        "properties": {
          "diaryId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "appended": {
            "type": "boolean"
          }
        }
      },
      "TransactionResponse": {
        "required": [
          "id",
          "diaryId",
          "symbol",
          "side",
          "quantity",
          "price",
          "currency",
          "tradedAt",
          "notes",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "diaryId": {
            "type": "string",
            "format": "uuid"
          },
          "symbol": {
            "type": "string"
          },
          "side": {
            "type": "string"
          },
          "quantity": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "price": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "tradedAt": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },

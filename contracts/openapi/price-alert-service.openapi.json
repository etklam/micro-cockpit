          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TriggerResponse": {
        "required": [
          "id",
          "tradingDate",
          "observedClose",
          "triggeredAt",
          "dismissedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tradingDate": {
            "type": "string",
            "format": "date"
          },
          "observedClose": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",

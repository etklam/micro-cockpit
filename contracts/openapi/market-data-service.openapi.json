  "components": {
    "schemas": {
      "BarsResponse": {
        "required": [
          "contractVersion",
          "symbol",
          "items"
        ],
        "type": "object",
        "properties": {
          "contractVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "symbol": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublishedBarResponse"
            }
          }
        }
      },
      "BarWrite": {
        "required": [
          "symbol",
          "tradingDate",
          "open",
          "high",
          "low",
          "close",
          "volume"
        ],
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "tradingDate": {
            "type": "string",
            "format": "date"
          },
          "open": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "high": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "low": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "close": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "volume": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CompleteRun": {
        "required": [
          "status",
          "error"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "error": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProviderHealthResponse": {
        "required": [
          "provider",
          "lastSuccessAt",
          "healthy"
        ],
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "lastSuccessAt": {
            "type": "string",
            "format": "date-time"
          },
          "healthy": {
            "type": "boolean"
          }
        }
      },
      "ProviderRunCreatedResponse": {
        "required": [
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ProviderRunWrite": {
        "required": [
          "provider"
        ],
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          }
        }
      },
      "ProvidersHealthResponse": {
        "required": [
          "contractVersion",
          "healthy",
          "items"
        ],
        "type": "object",
        "properties": {
          "contractVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "healthy": {
            "type": "boolean"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderHealthResponse"
            }
          }
        }
      },
      "PublishedBarResponse": {
        "required": [
          "tradingDate",
          "open",
          "high",
          "low",
          "close",
          "volume",
          "provider",
          "publishedAt"
        ],
        "type": "object",
        "properties": {
          "tradingDate": {
            "type": "string",
            "format": "date"
          },
          "open": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "high": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "low": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "close": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "volume": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "provider": {
            "type": "string"
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PublishedSymbolResponse": {
        "required": [
          "symbol",
          "name",
          "exchange",
          "currency",
          "timezone"
        ],
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "SymbolsResponse": {
        "required": [
          "contractVersion",
          "items"
        ],
        "type": "object",
        "properties": {
          "contractVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublishedSymbolResponse"
            }
          }
        }
      },
      "SymbolWrite": {
        "required": [
          "name",
          "exchange",
          "currency",
          "timezone"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "active": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "serviceKey": {
        "type": "apiKey",
        "name": "X-Service-Key",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "TradeDiary.MarketData"
    }
  ]
}

  "components": {
    "schemas": {
      "CollectionResponseOfDayCountResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DayCountResponse"
            }
          }
        }
      },
      "CollectionResponseOfDiaryAlertResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DiaryAlertResponse"
            }
          }
        }
      },
      "DayCountResponse": {
        "required": [
          "localDate",
          "count"
        ],
        "type": "object",
        "properties": {
          "localDate": {
            "type": "string",
            "format": "date"
          },
          "count": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          }
        }
      },
      "DaySummaryResponse": {
        "required": [
          "date",
          "count"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "count": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          }
        }
      },
      "DiaryAlertResponse": {
        "required": [
          "id",
          "diaryId",
          "startLocalDate",
          "nextLocalDate",
          "localTime",
          "timezone",
          "repeatMode",
          "recurrenceEndLocalDate",
          "nextTriggerAt",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "diaryId": {
            "type": "string",
            "format": "uuid"
          },
          "startLocalDate": {
            "type": "string",
            "format": "date"
          },
          "nextLocalDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "localTime": {
            "type": "string",
            "format": "time"
          },
          "timezone": {
            "type": "string"
          },
          "repeatMode": {
            "type": "string"
          },
          "recurrenceEndLocalDate": {
            "type": "string",
            "format": "date"
          },
          "nextTriggerAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DiaryAlertWrite": {
        "required": [
          "diaryId",
          "startLocalDate",
          "localTime",
          "timezone",
          "repeatMode"
        ],
        "type": "object",
        "properties": {
          "diaryId": {
            "type": "string",
            "format": "uuid"
          },
          "startLocalDate": {
            "type": "string",
            "format": "date"
          },
          "localTime": {
            "type": "string",
            "format": "time"
          },
          "timezone": {
            "type": "string"
          },
          "repeatMode": {
            "type": "string"
          }
        }
      },
      "DiaryDeletedEvent": {
        "required": [
          "eventId",
          "eventType",
          "version",
          "payload"
        ],
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "eventType": {
            "type": "string"
          },
          "version": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "payload": {
            "$ref": "#/components/schemas/DiaryDeletedPayload"
          }
        }
      },
      "DiaryDeletedPayload": {
        "required": [
          "diaryId",
          "userId"
        ],
        "type": "object",
        "properties": {
          "diaryId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "WorkerRunResult": {
        "required": [
          "delivered"
        ],
        "type": "object",
        "properties": {
          "delivered": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "serviceKey": {
        "type": "apiKey",
        "name": "X-Service-Key",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "TradeDiary.Reminder"
    }
  ]

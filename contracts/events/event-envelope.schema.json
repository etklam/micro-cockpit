{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://micro-cockpit.local/contracts/event-envelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "eventVersion", "occurredAt", "producer", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]+\\.v[1-9][0-9]*$" },
    "eventVersion": { "type": "integer", "minimum": 1 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "correlationId": { "type": ["string", "null"], "format": "uuid" },
    "causationId": { "type": ["string", "null"], "format": "uuid" },
    "payload": { "type": "object" }
  }
}
